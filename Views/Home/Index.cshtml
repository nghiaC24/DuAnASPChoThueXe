@{
    ViewData["Title"] = "KNP Rental - Innovative Solutions";
}

<!-- Thư viện hiệu ứng chuyển động khi cuộn trang -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

<style>
    :root {
        --dark-purple: #0f051d;
        --neon-pink: #ff4d6d;
        --glass-bg: rgba(255, 255, 255, 0.05);
    }

    body {
        background-color: var(--dark-purple);
        color: white;
        overflow-x: hidden;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* 1. Hero Section - Thay bằng ảnh banner-chinh.jpg */
    .hero-container {
        height: 100vh;
        background: linear-gradient(rgba(15, 5, 29, 0.5), rgba(15, 5, 29, 0.8)), url('/images/banner-chinh.jpg') center/cover;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    .hero-logo-text {
        font-size: 80px;
        font-weight: 900;
        letter-spacing: 15px;
        background: linear-gradient(to right, #fff, #ff85a2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
        text-transform: uppercase;
    }

    /* 2. Section "Our Mission" - Thay bằng ảnh anh-mission.jpg */
    .section-mission {
        padding: 120px 0;
        background: url('/images/anh-mission.jpg') center/cover fixed;
        position: relative;
    }

    .glass-card {
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 40px;
        padding: 60px;
        max-width: 850px;
        margin: 0 auto;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .title-line {
        width: 80px;
        height: 4px;
        background: var(--neon-pink);
        margin: 25px 0;
    }

    /* 3. Nút bấm */
    .btn-explore {
        border: 2px solid white;
        color: white;
        padding: 15px 45px;
        border-radius: 50px;
        font-weight: bold;
        text-transform: uppercase;
        transition: 0.4s;
        text-decoration: none;
        display: inline-block;
        margin-top: 30px;
    }

        .btn-explore:hover {
            background: white;
            color: var(--dark-purple);
            box-shadow: 0 0 30px rgba(255, 255, 255, 0.4);
            transform: scale(1.05);
        }

    .floating {
        animation: float 4s ease-in-out infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0px);
        }
    }
</style>

<!-- SECTION 1: HERO -->
<section class="hero-container">
    <div data-aos="zoom-out" data-aos-duration="2000">
        <h1 class="hero-logo-text">KNP RENTAL</h1>
        <p class="text-uppercase fw-bold" style="letter-spacing: 5px; opacity: 0.8;">Future of Mobility</p>
    </div>
    <div class="mt-5 floating">
        <i class="bi bi-chevron-double-down fs-1" style="color: var(--neon-pink)"></i>
    </div>
</section>

<!-- SECTION 2: OUR MISSION -->
<section class="section-mission">
    <div class="container">
        <div class="glass-card" data-aos="fade-up">
            <h2 class="display-3 fw-bold">Our Mission</h2>
            <div class="title-line"></div>
            <p class="lead" style="line-height: 1.8; opacity: 0.9;">
                Tại <strong>KNP Rental</strong>, sứ mệnh của chúng tôi là tái định nghĩa trải nghiệm di chuyển tại Sài Gòn.
                Chúng tôi không chỉ cung cấp phương tiện, mà còn mang đến những giải pháp công nghệ hiện đại,
                giúp mọi hành trình của bạn trở nên an toàn, nhanh chóng và đầy cảm hứng.
            </p>
            <a href="/Home/Index" class="btn-explore shadow">Khám phá ngay</a>
        </div>
    </div>
</section>

<!-- SECTION 3: ADVANTAGES - Thay bằng ảnh anh-uudiem.jpg -->
<section class="py-5" style="background: #080212;">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-md-6" data-aos="fade-right">
                <h3 class="fw-bold text-uppercase" style="color:var(--neon-pink); letter-spacing: 2px;">Ưu điểm vượt trội</h3>
                <div class="mt-5">
                    <div class="mb-5 border-start border-3 border-secondary ps-4">
                        <h4 class="fw-bold text-white">01. Uy Tín Tuyệt Đối</h4>
                        <p class="text-secondary">Dẫn đầu trong lĩnh vực thuê xe với hơn 200+ đầu xe đời mới nhất 2024.</p>
                    </div>
                    <div class="mb-5 border-start border-3 border-secondary ps-4">
                        <h4 class="fw-bold text-white">02. Minh Bạch & Công Nghệ</h4>
                        <p class="text-secondary">Hợp đồng điện tử ký kết ngay trên smartphone. Giá thuê công khai, cam kết không phát sinh.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 text-center" data-aos="fade-left">
                <!-- Chỗ này dùng ảnh anh-uudiem.jpg của bạn -->
                <img src="/images/anh-uudiem.jpg" class="img-fluid rounded-5 shadow-lg border border-secondary border-opacity-25" style="border-radius: 30px;">
            </div>
        </div>
    </div>
</section>

<!-- Script khởi tạo hiệu ứng cuộn -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 1200,
        once: true
    });
</script>