@model DuAnASPChoThueXe.Models.Car
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm Ô Tô Mới";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4 p-4">
        <h3 class="fw-bold mb-4 text-primary">Thêm Ô Tô Mới</h3>

        <!-- QUAN TRỌNG: Thêm enctype="multipart/form-data" để gửi được file ảnh -->
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Tên Xe</label>
                    <input asp-for="Name" class="form-control rounded-3" placeholder="Ví dụ: Toyota Vios" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Thương Hiệu</label>
                    <input asp-for="Brand" class="form-control rounded-3" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Số Chỗ</label>
                    <select asp-for="Seats" class="form-select rounded-3">
                        <option value="4">4 Chỗ</option>
                        <option value="5">5 Chỗ</option>
                        <option value="7">7 Chỗ</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-primary">Biển Số Xe</label>
                    <input asp-for="LicensePlate" class="form-control rounded-3 border-primary shadow-sm fw-bold text-uppercase" placeholder="51H-123.45" required>
                    <span asp-validation-for="LicensePlate" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Giá Thuê / Ngày</label>
                    <input asp-for="PricePerDay" type="number" class="form-control rounded-3" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Hộp Số</label>
                    <select asp-for="Transmission" class="form-select rounded-3">
                        <option value="Tự động">Tự động</option>
                        <option value="Số sàn">Số sàn</option>
                    </select>
                </div>

                <!-- THAY ĐỔI: Chọn file ảnh thay vì nhập link -->
                <div class="col-md-8">
                    <label class="form-label fw-bold text-success">Chọn Ảnh Xe (File từ máy tính)</label>
                    <input type="file" name="ImageFile" class="form-control rounded-3 border-success shadow-sm" accept="image/*" required onchange="previewImage(this)">
                    <small class="text-muted fst-italic">Lưu ý: Ảnh nên có định dạng .jpg, .png hoặc .webp</small>
                </div>

                <!-- Phần xem trước ảnh sau khi chọn file -->
                <div class="col-12 text-center my-2 d-none" id="previewContainer">
                    <p class="small fw-bold">Ảnh đã chọn:</p>
                    <img id="previewImg" src="#" class="img-fluid rounded-3 shadow-sm" style="max-height: 200px; border: 2px solid #eee;">
                </div>

                <div class="col-12">
                    <label class="form-label fw-bold">Mô Tả</label>
                    <textarea asp-for="Description" class="form-control rounded-3" rows="3" placeholder="Nhập các đặc điểm nổi bật của xe..."></textarea>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow">
                    <i class="bi bi-plus-circle me-2"></i> LƯU XE VÀO HỆ THỐNG
                </button>
                <a asp-action="Index" class="btn btn-light px-5 rounded-pill fw-bold border ms-2">HỦY</a>
            </div>
        </form>
    </div>
</div>

<script>
    // Hàm hiển thị ảnh ngay lập tức khi admin chọn file
    function previewImage(input) {
        const preview = document.getElementById('previewImg');
        const container = document.getElementById('previewContainer');

        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                container.classList.remove('d-none');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>