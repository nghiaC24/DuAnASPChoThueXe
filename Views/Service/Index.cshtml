@model IEnumerable<DuAnASPChoThueXe.Controllers.ServiceVM>
@{
    ViewData["Title"] = "Dịch Vụ Thuê Xe Tại TP.HCM";
}

<style>
    .service-header {
        border-bottom: 2px solid #ff85a2;
        display: inline-block;
        padding-bottom: 5px;
        margin-bottom: 30px;
        font-weight: bold;
        text-transform: uppercase;
    }

    .card-service {
        border: none;
        transition: 0.3s;
    }

        .card-service:hover {
            transform: translateY(-5px);
        }

        .card-service img {
            height: 200px;
            object-fit: cover;
            border-radius: 5px;
        }

    .service-title {
        font-size: 16px;
        font-weight: bold;
        color: #333;
        text-decoration: none;
        display: block;
        margin-top: 10px;
        line-height: 1.4;
    }

        .service-title:hover {
            color: #ff4d6d;
        }

    .service-meta {
        font-size: 12px;
        color: #888;
        margin-bottom: 8px;
    }

        .service-meta i {
            margin-right: 5px;
        }

    .service-desc {
        font-size: 14px;
        color: #666;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .badge-location {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(255, 77, 109, 0.8);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
    }
</style>

<div class="container py-5">
    <div class="text-center">
        <h2 class="service-header">Dịch Vụ Cho Thuê Xe Máy Tại TP.HCM</h2>
    </div>

    <div class="row g-4 mt-2">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card card-service h-100">
                    <div class="position-relative">
                        <!-- Khi nhấn vào ảnh sẽ dẫn về danh sách xe (Trang chủ) -->
                        <a asp-controller="Home" asp-action="Index">
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title">
                            <span class="badge-location">Tại TP.HCM</span>
                        </a>
                    </div>
                    <div class="card-body px-0">
                        <div class="service-meta">
                            <span><i class="bi bi-calendar3"></i> @item.Date</span>
                            <span class="ms-3"><i class="bi bi-clock"></i> 08:30</span>
                        </div>
                        <!-- Tiêu đề nhấn vào cũng dẫn về danh sách xe -->
                        <a asp-controller="Home" asp-action="Index" class="service-title">
                            @item.Title
                        </a>
                        <p class="service-desc mt-2">
                            @item.Description
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>