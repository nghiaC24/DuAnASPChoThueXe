@using Newtonsoft.Json
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thống Kê Doanh Thu";
    var dailyStats = ViewBag.DailyStats as IEnumerable<dynamic>;

    // Dữ liệu cho biểu đồ
    var chartLabels = dailyStats.Select(x => ((DateTime)x.Date).ToString("dd/MM")).Reverse().ToList();
    var chartData = dailyStats.Select(x => (decimal)x.Amount).Reverse().ToList();
}

<style>
    /* Biến màu sắc đồng bộ hệ thống */
    :root {
        --knp-blue: #0060a9;
        --knp-dark: #1e293b;
        --knp-success: #10b981;
    }

    /* KPI Cards */
    .stat-card {
        border: none;
        border-radius: 16px;
        padding: 1.5rem;
        background: white;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        transition: transform 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }

    .chart-container {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    }

    .quick-action-card {
        background: var(--knp-dark);
        color: white;
        border-radius: 20px;
        padding: 20px;
    }

    .btn-quick {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        text-align: left;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 10px;
        display: block;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-quick:hover {
            background: rgba(255,255,255,0.2);
            color: white;
        }

    .table-knp {
        background: white;
        border-radius: 20px;
        overflow: hidden;
    }

        .table-knp thead {
            background: #f8fafc;
        }

        .table-knp th {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #64748b;
            padding: 15px;
        }
</style>

<div class="container-fluid">
    <!-- Tiêu đề trang -->
    <div class="mb-4">
        <h2 class="fw-bold text-dark mb-1">Thống Kê Doanh Thu</h2>
        <p class="text-muted">Tổng quan tình hình kinh doanh của hệ thống KNP</p>
    </div>

    <!-- Hàng 1: Thẻ KPI -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary-subtle text-primary"><i class="bi bi-wallet2"></i></div>
                <div class="text-muted small fw-bold">TỔNG THU</div>
                <h4 class="fw-bold m-0 mt-1">@ViewBag.TotalRevenue.ToString("N0")<small>đ</small></h4>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-success-subtle text-success"><i class="bi bi-graph-up-arrow"></i></div>
                <div class="text-muted small fw-bold">HÔM NAY</div>
                <h4 class="fw-bold m-0 mt-1 text-success">@ViewBag.TodayRevenue.ToString("N0")<small>đ</small></h4>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info-subtle text-info"><i class="bi bi-calendar3"></i></div>
                <div class="text-muted small fw-bold">THÁNG NÀY</div>
                <h4 class="fw-bold m-0 mt-1">@ViewBag.MonthRevenue.ToString("N0")<small>đ</small></h4>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning-subtle text-warning"><i class="bi bi-cart-check"></i></div>
                <div class="text-muted small fw-bold">ĐƠN HÀNG</div>
                <h4 class="fw-bold m-0 mt-1">@ViewBag.TotalOrders</h4>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Biểu đồ -->
        <div class="col-lg-8">
            <div class="chart-container h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold m-0"><i class="bi bi-activity me-2"></i>Biểu đồ Xu hướng 7 Ngày</h6>
                    <span class="badge bg-light text-dark">Gần đây nhất</span>
                </div>
                <div style="height: 350px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Thao tác nhanh & Trạng thái -->
        <div class="col-lg-4">
            <div class="quick-action-card mb-4">
                <h6 class="fw-bold mb-3 small text-uppercase opacity-75">Thao tác nhanh</h6>
                <a asp-controller="AdminMotorbikes" asp-action="Create" class="btn-quick">
                    <i class="bi bi-plus-circle me-2"></i> Thêm xe máy mới
                </a>
                <a asp-controller="AdminBookings" asp-action="Index" class="btn-quick">
                    <i class="bi bi-file-earmark-check me-2"></i> Kiểm tra đơn thuê
                </a>
            </div>

            <div class="stat-card">
                <h6 class="fw-bold text-center mb-4 small text-uppercase">Tỷ lệ hoàn tất</h6>
                <div style="height: 200px;">
                    <canvas id="orderStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Bảng số liệu chi tiết -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="table-knp shadow-sm border-0">
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold m-0">Chi tiết doanh thu theo ngày</h6>
                    <a href="#" class="text-primary small text-decoration-none fw-bold">Xem tất cả</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Ngày giao dịch</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Số tiền thu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in dailyStats)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium">
                                        <i class="bi bi-calendar-event text-muted me-2"></i>
                                        @item.Date.ToString("dd/MM/yyyy")
                                    </td>
                                    <td><span class="badge bg-success-light text-success px-2 py-1 rounded-pill" style="background: #def7ec; font-size: 10px;">ĐÃ CHỐT</span></td>
                                    <td class="text-end pe-4 fw-bold text-primary">+ @item.Amount.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Biểu đồ đường xu hướng
        var labels = @Html.Raw(JsonConvert.SerializeObject(chartLabels));
        var dataValues = @Html.Raw(JsonConvert.SerializeObject(chartData));

        const revCtx = document.getElementById('revenueChart').getContext('2d');
        const gradient = revCtx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(0, 96, 169, 0.2)');
        gradient.addColorStop(1, 'rgba(0, 96, 169, 0)');

        new Chart(revCtx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu',
                    data: dataValues,
                    borderColor: '#0060a9',
                    borderWidth: 3,
                    backgroundColor: gradient,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#0060a9',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { borderDash: [5, 5], color: '#f1f5f9' }, ticks: { font: { size: 10 } } },
                    x: { grid: { display: false }, ticks: { font: { size: 10 } } }
                }
            }
        });

        // 2. Biểu đồ tròn trạng thái
        const statusCtx = document.getElementById('orderStatusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Hoàn thành', 'Chờ xử lý'],
                datasets: [{
                    data: [85, 15],
                    backgroundColor: ['#0060a9', '#e2e8f0'],
                    hoverOffset: 4,
                    borderWidth: 0
                }]
            },
            options: {
                cutout: '80%',
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 8, font: { size: 10 } } } }
            }
        });
    </script>
}