@model IEnumerable<DuAnASPChoThueXe.Models.CartItem>
@{
    ViewData["Title"] = "Thanh Toán Giỏ Hàng";
    var totalAmount = Model.Sum(x => x.Price * x.Quantity);
}

<style>
    :root {
        --knp-pink: #ff4d6d;
        --knp-pink-light: #fff0f3;
    }

    .cart-header {
        color: var(--knp-pink);
        border-bottom: 2px solid #ff85a2;
        display: inline-block;
        padding-bottom: 5px;
        font-weight: bold;
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    .form-checkout {
        background: #fff;
        padding: 25px;
        border: 1px solid #eee;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .btn-checkout {
        background: #f3801f;
        color: white;
        font-weight: 800;
        padding: 15px;
        border: none;
        width: 100%;
        text-transform: uppercase;
        border-radius: 50px;
        transition: 0.3s;
    }

        .btn-checkout:hover {
            background: #d66d12;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(243, 128, 31, 0.2);
        }

    .qr-box {
        background: #fff0f3;
        border: 2px dashed #ff85a2;
        border-radius: 10px;
        padding: 15px;
        display: none;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px 15px;
    }
    /* Plate badge trong giỏ hàng */
    .plate-mini {
        background: #334155;
        color: #fff;
        padding: 2px 8px;
        border-radius: 5px;
        font-size: 11px;
        margin-left: 5px;
    }
</style>

<div class="container py-5">
    <div class="row g-4">
        <!-- Cột TRÁI: Giỏ hàng -->
        <div class="col-lg-7">
            <h5 class="cart-header">GIỎ HÀNG CỦA BẠN:</h5>
            <div class="table-responsive">
                <table class="table align-middle border rounded-3 overflow-hidden">
                    <thead class="table-light text-center">
                        <tr>
                            <th>Hình Ảnh</th>
                            <th>Tên Xe & Biển Số</th>
                            <th>Số Lượng</th>
                            <th class="text-end">Thành Tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <img src="@(item.Motorbike != null ? item.Motorbike.ImageUrl : item.Car?.ImageUrl)" width="100" class="rounded-3 shadow-sm">
                                </td>
                                <td>
                                    <div class="fw-bold">@(item.Motorbike != null ? item.Motorbike.Name : item.Car?.Name)</div>
                                    <span class="plate-mini">@(item.Motorbike != null ? item.Motorbike.LicensePlate : item.Car?.LicensePlate)</span>
                                </td>
                                <td class="text-center">x @item.Quantity</td>
                                <td class="text-end fw-bold">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-4 bg-white rounded-3 mt-3 shadow-sm border text-end">
                <span class="text-muted text-uppercase small">Tổng thanh toán dự kiến:</span>
                <h3 class="text-danger fw-bold m-0">@totalAmount.ToString("N0") VNĐ</h3>
            </div>
        </div>

        <!-- Cột PHẢI: Form thanh toán -->
        <div class="col-lg-5">
            <div class="form-checkout animate__animated animate__fadeInRight">
                <form asp-action="ProcessCheckout" method="post" id="checkoutForm">

                    <h6 class="fw-bold mb-3 text-danger"><i class="bi bi-person-vcard me-2"></i>THÔNG TIN KHÁCH THUÊ:</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-12">
                            <input type="text" name="customerName" class="form-control" placeholder="Họ tên đầy đủ" required>
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="customerPhone" id="phone" class="form-control" placeholder="Số điện thoại (10 số)" maxlength="10" required>
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="citizenId" id="cccd" class="form-control" placeholder="Số CCCD (12 số)" maxlength="12" required>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-3 text-danger"><i class="bi bi-geo-alt me-2"></i>ĐỊA CHỈ NHẬN XE:</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-4">
                            <select class="form-select" id="city" name="province" required>
                                <option value="" selected disabled>Tỉnh/Thành</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <select class="form-select" id="district" name="district" required>
                                <option value="" selected disabled>Quận/Huyện</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <select class="form-select" id="ward" name="ward" required>
                                <option value="" selected disabled>Phường/Xã</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <input type="text" name="address" class="form-control" placeholder="Số nhà, tên đường..." required>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-3 text-danger"><i class="bi bi-wallet2 me-2"></i>THANH TOÁN:</h6>
                    <div class="form-check border p-3 rounded-3 mb-2">
                        <input class="form-check-input ms-0" type="radio" name="paymentMethod" value="Transfer" id="payT" onclick="toggleQR(true)">
                        <label class="form-check-label ms-2 fw-bold" for="payT">CHUYỂN KHOẢN (GIẢM 5%)</label>
                    </div>

                    <div id="qrSection" class="qr-box text-center mb-3">
                        <img src="https://api.vietqr.io/image/970422-0908630065-o8GZ5rN.jpg?accountName=KNP%20RENTAL&amount=@totalAmount" class="img-fluid border bg-white mb-2" style="max-width: 150px;">
                        <div class="small">Nội dung: <strong>THUE XE @DateTime.Now.ToString("ddMM")</strong></div>
                    </div>

                    <div class="form-check border p-3 rounded-3 mb-4">
                        <input class="form-check-input ms-0" type="radio" name="paymentMethod" value="COD" id="payC" checked onclick="toggleQR(false)">
                        <label class="form-check-label ms-2 fw-bold" for="payC">THANH TOÁN KHI NHẬN XE</label>
                    </div>

                    <button type="submit" class="btn-checkout shadow">XÁC NHẬN ĐẶT XE NGAY</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Đảm bảo có dòng nạp Axios này trên đầu đoạn script -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.21.1/axios.min.js"></script>

<script>
    const host = "https://provinces.open-api.vn/api/";

    var callAPI = (api) => {
        return fetch(api)
            .then((response) => response.json())
            .then((data) => {
                renderData(data, "city");
            });
    }

    // Gọi API lấy danh sách tỉnh ngay khi load trang
    callAPI(host + '?depth=1');

    var callApiDistrict = (api) => {
        return fetch(api)
            .then((response) => response.json())
            .then((data) => {
                renderData(data.districts, "district");
            });
    }

    var callApiWard = (api) => {
        return fetch(api)
            .then((response) => response.json())
            .then((data) => {
                renderData(data.wards, "ward");
            });
    }

    var renderData = (array, selectId) => {
        let row = ' <option disable value="">Chọn</option>';
        array.forEach(element => {
            row += `<option data-id="${element.code}" value="${element.name}">${element.name}</option>`
        });
        document.querySelector("#" + selectId).innerHTML = row;
    }

    // Sự kiện khi chọn Tỉnh
    document.querySelector("#city").addEventListener("change", () => {
        let selectedOption = document.querySelector("#city").options[document.querySelector("#city").selectedIndex];
        let id = selectedOption.getAttribute('data-id');
        callApiDistrict(host + "p/" + id + "?depth=2");
        document.querySelector("#ward").innerHTML = '<option value="">Chọn Phường/Xã</option>';
    });

    // Sự kiện khi chọn Quận
    document.querySelector("#district").addEventListener("change", () => {
        let selectedOption = document.querySelector("#district").options[document.querySelector("#district").selectedIndex];
        let id = selectedOption.getAttribute('data-id');
        callApiWard(host + "d/" + id + "?depth=2");
    });


   

    // Xử lý chỉ nhập số cho SĐT và CCCD
    document.getElementById('phone').addEventListener('input', function(e) { this.value = this.value.replace(/[^0-9]/g, ''); });
    document.getElementById('cccd').addEventListener('input', function(e) { this.value = this.value.replace(/[^0-9]/g, ''); });

    // Validate trước khi gửi
    document.getElementById('checkoutForm').onsubmit = function(e) {
        if (document.getElementById('phone').value.length < 10) { alert("SĐT phải đủ 10 số!"); return false; }
        if (document.getElementById('cccd').value.length < 12) { alert("CCCD phải đủ 12 số!"); return false; }
    };

    function toggleQR(s) { document.getElementById('qrSection').style.display = s ? 'block' : 'none'; }
</script>