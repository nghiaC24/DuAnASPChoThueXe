@model IEnumerable<DuAnASPChoThueXe.Models.CartItem>

<style>
    :root {
        --knp-pink: #ff4d6d;
        --knp-pink-light: #fff0f3;
        --knp-dark: #1a0b2e;
    }

    /* Bo góc và hiệu ứng đổ bóng cho Modal */
    .cart-modal-content {
        border-radius: 30px;
        border: none;
        overflow: hidden;
        box-shadow: 0 25px 80px rgba(0,0,0,0.2);
    }

    /* Header sang trọng */
    .cart-header {
        background: linear-gradient(135deg, #fff 0%, var(--knp-pink-light) 100%);
        padding: 20px 30px;
        border-bottom: 1px solid rgba(255, 77, 109, 0.1);
    }

        .cart-header h5 {
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--knp-dark);
            margin: 0;
        }

    /* Thiết kế từng dòng sản phẩm dạng Card */
    .cart-item-row {
        display: flex;
        align-items: center;
        padding: 15px;
        margin-bottom: 15px;
        background: #fff;
        border-radius: 20px;
        border: 1px solid #f0f0f0;
        transition: 0.3s;
    }

        .cart-item-row:hover {
            border-color: var(--knp-pink);
            transform: scale(1.01);
            box-shadow: 0 10px 20px rgba(255, 77, 109, 0.05);
        }

    .cart-item-img {
        width: 100px;
        height: 70px;
        object-fit: contain;
        background: #f9f9f9;
        border-radius: 15px;
        padding: 5px;
        margin-right: 20px;
    }

    .cart-item-info {
        flex-grow: 1;
    }

    .cart-item-name {
        font-weight: 700;
        font-size: 15px;
        color: var(--knp-dark);
        margin-bottom: 2px;
        display: block;
    }

    .cart-item-category {
        font-size: 11px;
        text-transform: uppercase;
        color: var(--knp-pink);
        font-weight: 700;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
    }

    /* Style cho nhãn Biển số xe */
    .license-badge {
        background: #334155;
        color: white;
        padding: 2px 8px;
        border-radius: 6px;
        font-size: 10px;
        margin-left: 8px;
        letter-spacing: 1px;
        font-family: 'Space Grotesk', sans-serif;
    }

    .cart-item-qty {
        background: var(--knp-pink-light);
        color: var(--knp-pink-dark);
        padding: 4px 12px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 13px;
        margin: 0 20px;
    }

    .cart-item-price {
        font-weight: 800;
        color: var(--knp-dark);
        font-size: 16px;
        min-width: 120px;
        text-align: right;
    }

    .cart-summary {
        background: #f8f9fa;
        padding: 25px 30px;
        border-top: 1px dashed #ddd;
    }

    .total-label {
        font-weight: 600;
        color: #666;
        font-size: 14px;
    }

    .total-amount {
        font-weight: 900;
        color: var(--knp-pink);
        font-size: 24px;
    }

    .btn-checkout {
        background: var(--knp-pink);
        color: white;
        border: none;
        padding: 12px 35px;
        border-radius: 50px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
        box-shadow: 0 10px 20px rgba(255, 77, 109, 0.2);
        text-decoration: none;
        display: inline-block;
    }

        .btn-checkout:hover {
            background: var(--knp-pink-dark);
            transform: translateY(-3px);
            color: white;
        }
</style>

<div class="modal-content cart-modal-content">
    <div class="modal-header cart-header border-0">
        <h5 class="modal-title"><i class="bi bi-bag-heart-fill me-2 text-danger"></i>GIỎ HÀNG CỦA BẠN</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <div class="modal-body p-4" style="max-height: 450px; overflow-y: auto;">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x fs-1 opacity-20"></i>
                <p class="mt-3 text-muted">Giỏ hàng đang trống</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="cart-item-row animate__animated animate__fadeInUp">
                    <img src="@(item.Car != null ? item.Car.ImageUrl : item.Motorbike?.ImageUrl)" class="cart-item-img shadow-sm">

                    <div class="cart-item-info">
                        <div class="cart-item-category">
                            @(item.Car != null ? "Ô TÔ " + item.Car.Seats + " CHỖ" : "XE MÁY")

                            <!-- HIỂN THỊ BIỂN SỐ XE Ở ĐÂY -->
                            <span class="license-badge">
                                <i class="bi bi-tag-fill me-1" style="font-size: 8px;"></i>
                                @(item.Car != null ? item.Car.LicensePlate : item.Motorbike?.LicensePlate)
                            </span>
                        </div>
                        <span class="cart-item-name">@(item.Car != null ? item.Car.Name : item.Motorbike?.Name)</span>
                    </div>

                    <div class="cart-item-qty">x @item.Quantity</div>

                    <div class="cart-item-price">
                        @((item.Price * item.Quantity).ToString("N0")) <small>đ</small>
                    </div>
                </div>
            }
        }
    </div>

    <div class="cart-summary border-0">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="total-label text-uppercase">Tổng thanh toán dự kiến</span>
            <span class="total-amount">@Model.Sum(x => x.Price * x.Quantity).ToString("N0") <small>VNĐ</small></span>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <a href="#" data-bs-dismiss="modal" class="btn-continue">
                <i class="bi bi-arrow-left me-1"></i> Tiếp tục chọn xe
            </a>
            <a href="/Cart" class="btn btn-checkout">
                THANH TOÁN NGAY <i class="bi bi-chevron-right ms-1"></i>
            </a>
        </div>
    </div>
</div>