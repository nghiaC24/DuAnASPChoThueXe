@{ ViewData["Title"] = "Đăng Nhập"; }
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4 p-4" style="border-top: 5px solid #ff85a2 !important;">
                <h3 class="text-center fw-bold mb-4" style="color: #ff4d6d;">ĐĂNG NHẬP</h3>
                @if (ViewBag.Error != null) { <div class="alert alert-danger small">@ViewBag.Error</div> }
                @if (TempData["Success"] != null) { <div class="alert alert-success small">@TempData["Success"]</div> }
                
                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Email</label>
                        <input type="email" name="email" class="form-control rounded-pill px-3" required placeholder="name@example.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Mật khẩu</label>
                        <input type="password" name="password" class="form-control rounded-pill px-3" required placeholder="******">
                    </div>
                    <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold py-2 mt-3" style="background:#ff4d6d">ĐĂNG NHẬP</button>
                </form>
                <div class="text-center mt-4">
                    <span class="small">Chưa có tài khoản?</span> 
                    <a asp-action="Register" class="small fw-bold text-decoration-none" style="color:#ff85a2">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>