@model IEnumerable<DuAnASPChoThueXe.Models.Booking>
@{
    ViewData["Title"] = "Lịch sử thuê xe";
    Layout = "_Layout";
}

<div class="container py-5">
    <h3 class="fw-bold mb-4" style="color: #ff4d6d;"><i class="bi bi-clock-history me-2"></i>LỊCH SỬ THUÊ XE CỦA BẠN</h3>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-calendar-x fs-1 text-muted opacity-25"></i>
            <p class="mt-3 text-muted">Bạn chưa có đơn thuê xe nào.</p>
            <a href="/" class="btn btn-danger rounded-pill px-4">Thuê xe ngay</a>
        </div>
    }
    else
    {
        <div class="table-responsive bg-white p-3 rounded-4 shadow-sm">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ngày thuê</th>
                        <th>Thông tin xe</th>
                        <th>Biển số</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StartDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold">
                                @(item.Motorbike != null ? item.Motorbike.Name : item.Car?.Name)
                            </td>
                            <td>
                                <span class="badge bg-dark">
                                    @(item.Motorbike != null ? item.Motorbike.LicensePlate : item.Car?.LicensePlate)
                                </span>
                            </td>
                            <td class="text-danger fw-bold">@item.TotalPrice.ToString("N0") đ</td>
                            <td>
                                @if (item.ActualReturnDate.HasValue)
                                {
                                    <span class="badge bg-success">Đã hoàn thành</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Đang thuê / Chờ xác nhận</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>