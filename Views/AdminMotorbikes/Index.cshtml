@model IEnumerable<DuAnASPChoThueXe.Models.Motorbike>

@{
    // Dòng này cực kỳ quan trọng để đổi từ màu hồng sang menu đen của Admin
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Danh Sách Xe";
}

<div class="card shadow-sm border-0 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark">Danh Sách Xe Trong Hệ Thống</h3>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow">
            <i class="bi bi-plus-circle me-2"></i> Thêm Xe Mới
        </a>
    </div>

    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Ảnh</th>
                <th>Tên Xe</th>
                <th>Phân Khối</th>
                <th>Giá Thuê</th>
                <th class="text-center">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.ImageUrl" width="70" class="rounded border shadow-sm"
                             onerror="this.src='https://placehold.co/100x100?text=No+Image'">
                    </td>
                    <td class="fw-bold">@item.Name</td>
                    <td><span class="badge bg-light text-dark border">@item.Capacity</span></td>
                    <td class="text-danger fw-bold">@item.PricePerDay.ToString("N0") đ</td>
                    <td class="text-center">
                        <a href="#" class="btn btn-sm btn-outline-warning me-2"><i class="bi bi-pencil"></i></a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Bạn có chắc chắn muốn xóa xe này?')">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>