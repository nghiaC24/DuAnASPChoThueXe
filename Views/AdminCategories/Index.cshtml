@model IEnumerable<DuAnASPChoThueXe.Models.Category>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Loại Xe";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .cat-card {
        background: white;
        border-radius: 20px;
        border: none;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border-left: 5px solid #0060a9;
        transition: transform 0.2s ease;
    }

        .cat-card:hover {
            transform: translateY(-5px);
        }

    .cat-icon-box {
        width: 50px;
        height: 50px;
        background: #f0f7ff;
        color: #0060a9;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .cat-badge {
        font-size: 11px;
        font-weight: 700;
        padding: 5px 12px;
        border-radius: 20px;
        text-transform: uppercase;
    }

    .badge-motor {
        background: #e1effe;
        color: #1e429f;
    }

    .badge-car {
        background: #def7ec;
        color: #03543f;
    }

    .btn-cat-action {
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 14px;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-dark m-0">Quản Lý Danh Mục Loại Xe</h2>
            <p class="text-muted small">Thêm các loại như Xe số, Xe tay ga... để hiện thị lúc thêm xe mới</p>
        </div>
        <a href="/AdminCategories/Create" class="btn btn-primary px-4 py-2 shadow" style="background: #0060a9; border: none; border-radius: 12px;">
            <i class="fas fa-plus me-2"></i> Thêm Loại Xe Mới
        </a>
    </div>

    <!-- Thanh tìm kiếm & Bộ lọc -->
    <div class="bg-white p-3 rounded-4 shadow-sm mb-4 border-0">
        <div class="row g-2">
            <div class="col-md-8">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" id="searchInput" class="form-control bg-light border-0" placeholder="Tìm kiếm tên loại xe...">
                </div>
            </div>
            <div class="col-md-4">
                <select class="form-select bg-light border-0" id="filterType">
                    <option value="">Tất cả phân loại</option>
                    <option value="Xe máy">Xe máy</option>
                    <option value="Ô tô">Ô tô</option>
                </select>
            </div>
        </div>
    </div>

    <div class="row" id="categoryList">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-xl-4 category-item" data-name="@item.Name.ToLower()" data-type="@(item.Name.Contains("Ô tô") ? "Ô tô" : "Xe máy")">
                <div class="cat-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center">
                            <div class="cat-icon-box me-3">
                                @if (item.Name.Contains("Ô tô") || item.Name.Contains("xe hơi"))
                                {
                                    <i class="fas fa-car"></i>
                                }
                                else
                                {

                                    <i class="fas fa-motorcycle"></i>
                                }
                            </div>
                            <div>
                                <div class="text-muted small">ID: #@item.Id.ToString("000")</div>
                                <h5 class="fw-bold m-0">@item.Name</h5>
                            </div>
                        </div>
                        <span class="cat-badge @(item.Name.Contains("Ô tô") ? "badge-car" : "badge-motor")">
                            @(item.Name.Contains("Ô tô") ? "Ô TÔ" : "XE MÁY")
                        </span>
                    </div>
                    <hr class="opacity-25">
                    <div class="d-flex gap-2">
                        <a href="/AdminCategories/Edit/@item.Id" class="btn btn-light btn-cat-action text-warning flex-grow-1"><i class="fas fa-edit me-1"></i> Sửa</a>
                        <a href="/AdminCategories/Delete/@item.Id" onclick="return confirm('Xác nhận xóa?')" class="btn btn-light btn-cat-action text-danger flex-grow-1"><i class="fas fa-trash me-1"></i> Xóa</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Logic Tìm kiếm và Lọc nhanh
        $(document).ready(function () {
            $("#searchInput, #filterType").on("keyup change", function () {
                var searchText = $("#searchInput").val().toLowerCase();
                var filterValue = $("#filterType").val();

                $(".category-item").each(function () {
                    var name = $(this).data("name");
                    var type = $(this).data("type");

                    var matchSearch = name.indexOf(searchText) > -1;
                    var matchFilter = filterValue === "" || type === filterValue;

                    if (matchSearch && matchFilter) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });
        });
    </script>
}