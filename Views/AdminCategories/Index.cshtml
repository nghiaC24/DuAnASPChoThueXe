@model IEnumerable<DuAnASPChoThueXe.Models.Category>
@{
    Layout = "_AdminLayout"; ViewData["Title"] = "Quản Lý Loại Xe";
}

<div class="card card-custom p-4">
    <div class="text-end mb-3">
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">THÊM LOẠI XE MỚI</a>
    </div>
    <table class="table table-hover align-middle text-center">
        <thead class="table-dark">
            <tr><th>ID</th><th>Tên Loại Xe</th><th>Thao Tác</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td class="fw-bold">@item.Name</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger" onclick="return confirm('Xóa loại xe này?')"><i class="bi bi-trash fs-5"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>