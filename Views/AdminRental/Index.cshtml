@model IEnumerable<DuAnASPChoThueXe.Models.RentalViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Khách Thuê";
}

<style>
    .plate-badge {
        background-color: #334155;
        color: #fff;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 6px;
        display: inline-block;
        font-family: 'Space Grotesk';
    }

    .search-input {
        border-radius: 10px 0 0 10px !important;
        border: 1px solid #dee2e6;
    }

    .search-btn {
        border-radius: 0 10px 10px 0 !important;
    }
</style>

<div class="container-fluid">
    <div class="card shadow-sm border-0 animate__animated animate__fadeIn">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="fw-bold m-0 text-dark"><i class="bi bi-people-fill me-2 text-primary"></i>Quản Lý Thuê Xe</h5>
                </div>
                <!-- Thanh tìm kiếm mới -->
                <div class="col-md-6">
                    <form method="get" class="d-flex">
                        <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control search-input" placeholder="Tìm tên, SĐT hoặc biển số...">
                        <button class="btn btn-primary search-btn" type="submit"><i class="bi bi-search"></i></button>
                    </form>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">Khách Hàng</th>
                            <th>Xe & Biển Số</th>
                            <th>Ngày Thuê</th>
                            <th>Trạng Thái</th>
                            <th class="text-center">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold">@item.TenKhachHang</div>
                                    <small class="text-muted">@item.SoDienThoai</small>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.TenXe</div>
                                    @* Đảm bảo biển số luôn hiện dù là Ô tô hay Xe máy *@
                                    @if (!string.IsNullOrEmpty(item.BienSoXe) && item.BienSoXe != "---")
                                    {
                                        <div class="plate-badge">@item.BienSoXe</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border" style="font-size:10px;">Chưa cập nhật biển</span>
                                    }
                                </td>
                                <td class="small">@item.NgayThue.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.NgayTraThucTe.HasValue)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-2 py-1">
                                            <i class="bi bi-check-circle-fill me-1"></i> Đã trả xe
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning-emphasis border border-warning px-2 py-1">
                                            <i class="bi bi-clock-history me-1"></i> Đang thuê
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <!-- NÚT CHI TIẾT: Để xem CCCD, địa chỉ của đơn này -->
                                        <a href="/AdminBookings/Details/@item.IdDonThue" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                            <i class="bi bi-eye"></i> Chi tiết
                                        </a>

                                        @if (!item.NgayTraThucTe.HasValue)
                                        {
                                            <form asp-action="ConfirmReturn" method="post">
                                                <input type="hidden" name="id" value="@item.IdDonThue" />
                                                <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                                    Xác nhận trả
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="btn btn-sm btn-light disabled rounded-pill px-3">Hoàn tất</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>