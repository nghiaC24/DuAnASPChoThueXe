<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Trị KNP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        :root {
            --admin-pink: #ff4d6d;
            --sidebar-bg: #1a1c1e;
        }

        body {
            background-color: #f4f7f6;
            display: flex;
            min-height: 100vh;
            margin: 0;
        }

        #sidebar {
            min-width: 250px;
            background: var(--sidebar-bg);
            color: white;
            position: sticky;
            top: 0;
            height: 100vh;
        }

            #sidebar .nav-link {
                color: #aab0b6;
                padding: 15px 25px;
                border-bottom: 1px solid #2d2f31;
                transition: 0.3s;
            }

                #sidebar .nav-link:hover, #sidebar .nav-link.active {
                    background: var(--admin-pink);
                    color: white;
                }

        .main-content {
            flex: 1;
            padding: 30px;
        }

        .card-custom {
            border: none;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>
    <nav id="sidebar">
        <div class="p-4 text-center border-bottom border-secondary mb-3">
            <img src="/images/logo-knp.jpg" height="50" class="bg-white rounded p-1 mb-2">
            <h5 class="fw-bold mb-0">ADMIN PANEL</h5>
        </div>
        <ul class="nav flex-column">
            <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house-door me-2"></i> Xem Website</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="AdminMotorbikes" asp-action="Index"><i class="bi bi-bicycle me-2"></i> Quản Lý Xe</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="AdminBookings" asp-action="Index"><i class="bi bi-cart-check me-2"></i> Đơn Thuê Xe</a></li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="AdminCategories" asp-action="Index">
                    <i class="bi bi-tags me-2"></i> Quản Lý Loại Xe
                </a>
            </li>
            
            <li class="nav-item">
                <a class="nav-link" asp-controller="AdminDashboard" asp-action="Index">
                    <i class="bi bi-speedometer2 me-2 text-warning"></i> THỐNG KÊ DOANH THU
                </a>
            </li>
            <li class="nav-item"><a class="nav-link text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng Xuất</a></li>
        </ul>
    </nav>
    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">@ViewData["Title"]</h2>
            <div class="badge bg-dark p-2">Chào, Admin KNP</div>
        </div>
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>