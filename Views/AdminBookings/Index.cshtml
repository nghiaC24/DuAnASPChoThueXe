@model IEnumerable<DuAnASPChoThueXe.Models.Booking>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Đơn Thuê Xe";
}

<div class="card shadow-sm border-0 p-4" style="border-radius: 15px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr class="text-uppercase small fw-bold">
                    <th>Khách Hàng</th>
                    <th>SĐT</th>
                    <th>Xe Thuê</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng Thái</th>
                    <th class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.CustomerName</strong></td>
                        <td><span class="text-muted">@item.CustomerPhone</span></td>
                        <td><span class="badge bg-light text-dark border">@item.Motorbike?.Name</span></td>
                        <td class="text-danger fw-bold">@item.TotalPrice.ToString("N0") đ</td>
                        <td>
                            <span class="badge @(item.Status.Contains("xác nhận") ? "bg-success" : "bg-warning text-dark") px-3 py-2">
                                @item.Status
                            </span>
                        </td>
                        <td class="text-center">
                            <!-- NÚT XEM CHI TIẾT VÀ IN HÓA ĐƠN -->
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white rounded-pill px-3 me-2 shadow-sm">
                                <i class="bi bi-eye-fill"></i> Chi tiết
                            </a>

                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="status" onchange="this.form.submit()" class="form-select form-select-sm d-inline w-auto rounded-pill border-secondary">
                                    <option>Đổi trạng thái</option>
                                    <option value="Đã xác nhận">Xác nhận đơn</option>
                                    <option value="Đã giao xe">Đã giao xe</option>
                                    <option value="Hoàn thành">Hoàn thành</option>
                                    <option value="Đã hủy">Hủy đơn</option>
                                </select>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>